{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "harness-seed: REPL",
      "cargo": {
        "args": ["build", "--bin=harness-seed", "--package=harness-seed"],
        "filter": { "name": "harness-seed", "kind": "bin" }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "harness-seed: REPL (verbose)",
      "cargo": {
        "args": ["build", "--bin=harness-seed", "--package=harness-seed"],
        "filter": { "name": "harness-seed", "kind": "bin" }
      },
      "args": ["-v"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "harness-seed: REPL (rule brain)",
      "cargo": {
        "args": ["build", "--bin=harness-seed", "--package=harness-seed"],
        "filter": { "name": "harness-seed", "kind": "bin" }
      },
      "args": ["--no-llm"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "harness-seed: REPL (Ollama sample)",
      "cargo": {
        "args": ["build", "--bin=harness-seed", "--package=harness-seed"],
        "filter": { "name": "harness-seed", "kind": "bin" }
      },
      "args": ["--config", "config/samples/config.ollama.json"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Tests: lib (all unit)",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--package=harness-seed"],
        "filter": { "name": "harness-seed", "kind": "lib" }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Tests: integration (all)",
      "cargo": {
        "args": ["test", "--no-run", "--tests", "--package=harness-seed"],
        "filter": { "name": "harness-seed", "kind": "test" }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Tests: llm_connector_test",
      "cargo": {
        "args": [
          "test",
          "--no-run",
          "--test=llm_connector_test",
          "--package=harness-seed"
        ],
        "filter": { "name": "llm_connector_test", "kind": "test" }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Tests: self_intro_test",
      "cargo": {
        "args": [
          "test",
          "--no-run",
          "--test=self_intro_test",
          "--package=harness-seed"
        ],
        "filter": { "name": "self_intro_test", "kind": "test" }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1"
      }
    }
  ]
}
